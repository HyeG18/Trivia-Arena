<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  LAYOUT NOTES
  ─────────────────────────────────────────────────────────────────────
  JavaFX does NOT support percentage values in inline CSS (e.g. max-width:80%).
  Width constraints MUST be set via FXML attributes (maxWidth, prefWidth) or
  via absolute pixel values in CSS.  All percentage-based styles have been
  removed and replaced with proper JavaFX attributes.
-->
<StackPane fx:id="arenaRoot" styleClass="root"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.arenadepreguntas.client.controller.ArenaController">
    <children>

        <!-- ══ MAIN ARENA CONTAINER ══════════════════════════════════════ -->
        <VBox maxWidth="Infinity" maxHeight="Infinity">
            <children>

                <!-- Header Bar -->
                <HBox alignment="CENTER_LEFT" spacing="24"
                      maxWidth="Infinity"
                      style="-fx-background-color: linear-gradient(to bottom, #6A0DAD, #8B2FBF);
                             -fx-padding: 16; -fx-min-height: 72;">
                    <!-- Left: Avatar + Username -->
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <StackPane fx:id="avatarCircle" styleClass="avatar-circle">
                            <Label fx:id="avatarInitial" styleClass="avatar-initial" text="P"/>
                        </StackPane>
                        <Label fx:id="headerUsername" styleClass="label-username" text="Player"/>
                    </HBox>

                    <!-- Centre: Score (spacer pushes it to the middle) -->
                    <HBox HBox.hgrow="ALWAYS" alignment="CENTER">
                        <Label fx:id="scoreLabel" styleClass="label-score" text="0 pts"/>
                    </HBox>

                    <!-- Right: Rank Badge -->
                    <Label fx:id="rankBadge" styleClass="rank-badge" text="# —"/>
                </HBox>

                <!-- Timer Bar — maxWidth=Infinity fills the full window width -->
                <ProgressBar fx:id="timerBar"
                             prefHeight="18"
                             maxWidth="Infinity"
                             progress="1.0"
                             style="-fx-padding: 0;"/>

                <!-- ── Main Content Area ─────────────────────────────── -->
                <VBox alignment="CENTER" spacing="24"
                      style="-fx-padding: 32 48 32 48;"
                      VBox.vgrow="ALWAYS">

                    <!-- Question Card
                         maxWidth="Infinity" lets the VBox fill its parent;
                         the parent's padding (48 px each side) provides the margins. -->
                    <VBox fx:id="questionCard"
                          alignment="CENTER" spacing="12"
                          maxWidth="Infinity"
                          styleClass="card-surface"
                          style="-fx-padding: 28;">
                        <Label fx:id="questionMeta"
                               styleClass="label-question-meta"
                               text="Question — of —"/>
                        <Label fx:id="questionText"
                               styleClass="heading-medium"
                               text="⏳  Waiting for the game to start…"
                               textAlignment="CENTER"
                               wrapText="true"
                               maxWidth="Infinity"/>
                    </VBox>

                    <!-- Answer Grid
                         hgrow="ALWAYS" on both columns → each column gets 50 % of the width.
                         maxWidth="Infinity" → grid fills the parent VBox. -->
                    <GridPane hgap="14" vgap="14" maxWidth="Infinity">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints vgrow="ALWAYS" minHeight="80"/>
                            <RowConstraints vgrow="ALWAYS" minHeight="80"/>
                        </rowConstraints>

                        <Button fx:id="answerBtnA"
                                maxWidth="Infinity" maxHeight="Infinity"
                                onAction="#handleAnswerClickedA"
                                styleClass="btn-answer,btn-answer-red"
                                text="🔴  A."
                                GridPane.columnIndex="0" GridPane.rowIndex="0"/>

                        <Button fx:id="answerBtnB"
                                maxWidth="Infinity" maxHeight="Infinity"
                                onAction="#handleAnswerClickedB"
                                styleClass="btn-answer,btn-answer-blue"
                                text="🔵  B."
                                GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Button fx:id="answerBtnC"
                                maxWidth="Infinity" maxHeight="Infinity"
                                onAction="#handleAnswerClickedC"
                                styleClass="btn-answer,btn-answer-yellow"
                                text="🟡  C."
                                GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                        <Button fx:id="answerBtnD"
                                maxWidth="Infinity" maxHeight="Infinity"
                                onAction="#handleAnswerClickedD"
                                styleClass="btn-answer,btn-answer-green"
                                text="🟢  D."
                                GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    </GridPane>

                </VBox>
            </children>
        </VBox>

        <!-- ══ LEADERBOARD OVERLAY (included FXML, slide-up card) ════════ -->
        <fx:include fx:id="leaderboardOverlay" source="leaderboard_overlay.fxml"/>

        <!-- ══ EMOJI FLOAT LAYER — pointer events pass through ══════════ -->
        <StackPane fx:id="emojiOverlay"
                   mouseTransparent="true"
                   maxWidth="Infinity" maxHeight="Infinity"
                   style="-fx-background-color: transparent;"/>

    </children>
</StackPane>
